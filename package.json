{
  "name": "expense-buddy",
  "main": "expo-router/entry",
  "version": "3.2.0",
  "packageManager": "yarn@4.5.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudokoi/expense-buddy.git"
  },
  "scripts": {
    "upgrade:tamagui": "yarn up '*tamagui*'@latest '@tamagui/*'@latest",
    "upgrade:tamagui:canary": "yarn up '*tamagui*'@canary '@tamagui/*'@canary",
    "check:tamagui": "tamagui check",
    "start": "expo start -c",
    "android": "expo run:android",
    "build:android:internal:local": "node ./scripts/build-android-internal-local.js",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix --max-warnings=0",
    "check:translations": "node scripts/check-translations.js",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "ml:sync": "uv sync --directory tools/sms-ml --project .",
    "ml:import:seed": "uv run --directory tools/sms-ml --project . python scripts/import_seed_reference.py",
    "ml:prepare:seed": "uv run --directory tools/sms-ml --project . python scripts/normalize_seed_reference.py",
    "ml:labels:init": "uv run --directory tools/sms-ml --project . python scripts/init_seed_label_queue.py",
    "ml:labels:apply": "uv run --directory tools/sms-ml --project . python scripts/apply_seed_labels.py",
    "ml:benchmark:seed": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_current_regex.py",
    "ml:benchmark:taxonomy": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_taxonomy_first.py",
    "ml:train:seed-logreg": "uv run --directory tools/sms-ml --project . python scripts/train_seed_logreg.py",
    "ml:benchmark:logreg": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_logreg.py",
    "ml:train:seed-litert": "uv run --directory tools/sms-ml --project . python scripts/train_seed_litert.py",
    "ml:benchmark:litert": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_litert.py",
    "ml:train:seed-litert-embed": "uv run --directory tools/sms-ml --project . python scripts/train_seed_litert_embed.py",
    "ml:benchmark:litert-embed": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_litert_embed.py",
    "ml:prepare:seed-augmented": "uv run --directory tools/sms-ml --project . python scripts/prepare_seed_augmented_dataset.py",
    "ml:train:seed-litert-embed:augmented": "uv run --directory tools/sms-ml --project . python scripts/train_seed_litert_embed_augmented.py",
    "ml:benchmark:litert-embed:augmented": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_litert_embed_augmented.py",
    "ml:train:seed-litert-attention": "uv run --directory tools/sms-ml --project . python scripts/train_seed_litert_attention.py",
    "ml:benchmark:litert-attention": "uv run --directory tools/sms-ml --project . python scripts/benchmark_seed_litert_attention.py",
    "ml:export:seed-litert:android": "uv run --directory tools/sms-ml --project . python scripts/export_seed_litert_android.py",
    "ml:export:best-android": "uv run --directory tools/sms-ml --project . python scripts/export_seed_litert_android.py",
    "ml:lint": "uv run --directory tools/sms-ml --project . ruff check .",
    "ml:format": "uv run --directory tools/sms-ml --project . ruff format .",
    "ml:format:check": "uv run --directory tools/sms-ml --project . ruff format --check .",
    "ml:typecheck": "uv run --directory tools/sms-ml --project . pyright",
    "ml:test": "uv run --directory tools/sms-ml --project . pytest",
    "ml:check": "yarn ml:lint && yarn ml:format:check && yarn ml:typecheck && yarn ml:test"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@tamagui/config": "^1.144.3",
    "@tamagui/lucide-icons": "^1.144.3",
    "@tamagui/toast": "^1.144.3",
    "@types/papaparse": "^5.5.2",
    "@xstate/react": "^6.0.0",
    "@xstate/store": "^3.15.0",
    "babel-preset-expo": "~54.0.10",
    "burnt": "^0.12.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.0",
    "intl-pluralrules": "^2.0.1",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.1",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "tamagui": "^1.144.3",
    "xstate": "^5.25.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@expo/metro-runtime": "~6.1.2",
    "@tamagui/babel-plugin": "^1.144.3",
    "@tamagui/cli": "^1.144.3",
    "@tamagui/metro-plugin": "^1.144.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.17",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "fast-check": "^4.5.3",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.17",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
